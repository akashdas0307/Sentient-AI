# Cloud LLM API keys
# Required for MVS: at least ANTHROPIC_API_KEY
ANTHROPIC_API_KEY=your_anthropic_key_here

# Optional fallback providers
GOOGLE_API_KEY=
OPENAI_API_KEY=

# Local Ollama (defaults usually work)
OLLAMA_BASE_URL=http://localhost:11434

# System paths (defaults are fine)
SENTIENT_DATA_DIR=./data
SENTIENT_CONFIG_DIR=./config

# Logging
LOG_LEVEL=INFO

# API server
API_HOST=127.0.0.1
API_PORT=8765
